[user]
	name = Shinra Yamakawa
	email = s.yamakawa@flatt.tech
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDvQze+HOHpQPzD5Uv6yu+wtUh+Zpe9I2HXn1KwadphZ
[fetch]
	prune = true
[core]
	ignorecase = false
	quotepath = false
	editor = nvim
[color]
	ui = true
	diff = auto
	status = auto
	branch = auto
[init]
	defaultBranch = main
[gpg]
	format = ssh
[commit]
	gpgsign = true

# Include OS-specific config (ignored if file doesn't exist)
[include]
	path = ~/.config/git/local.inc
[safe]
	directory = /Users/pc0038/work_dir/puchisunaba/phase2
